# Used by the Vite build in production.
# When your Express backend is deployed as Vercel API routes under the same project,
# set this to an empty string so calls resolve to `/api/...`.
#
# If your backend is hosted separately, set it to the full origin, e.g.:
# VITE_API_BASE_URL=https://your-backend.vercel.app
VITE_API_BASE_URL=

